{
  "tags": {
    "allowUnknownTags": true
  },
  "source": {
    "include": [
      "packages/library/src",
      "packages/library-extension/src"
    ],
    "includePattern": "\\.(jsx|js|ts|tsx)$"
  },
  "plugins": [
    "plugins/markdown"
  ],
  "markdown": {
    "tags": ["load"]
  },
  "opts": {
    "destination": "docs",
    "recurse": true,
    "readme": "README.md"
  }
}
